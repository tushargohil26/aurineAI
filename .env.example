# Aurine AI Assistant v3.0 - Configuration
# ==========================================

# AI Provider: aurine (local), ollama, openai, anthropic, google, groq, openrouter, deepseek, mistral, custom
AI_PROVIDER=aurine

# OpenAI
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_CHAT_MODEL=gemini-2.0-flash

# Groq (Fast inference)
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# OpenRouter (Multi-provider gateway)
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=anthropic/claude-sonnet-4

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_CHAT_MODEL=deepseek-chat

# Mistral
MISTRAL_API_KEY=
MISTRAL_CHAT_MODEL=mistral-large-latest

# Ollama (Local)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Aurine Native (Local Ollama)
AURINE_NATIVE_MODEL=qwen2.5-coder:7b
AURINE_EMBEDDING_MODEL=nomic-embed-text

# Database & Files
VECTOR_DB=./vector_store.sqlite3
DATA_DIR=./data
GENERATED_PROJECTS_DIR=./generated_projects

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Image Generation
IMAGE_GENERATION_MODEL=dall-e-3
IMAGE_GENERATION_SIZE=1024x1024

# Advanced Features
REASONING_ENABLED=true
MEMORY_ENABLED=true
AUTO_AGENT_ROUTING=true
SELF_VERIFY=false
CHAIN_OF_THOUGHT=true
MAX_HISTORY_TURNS=20
MAX_TOOL_ITERATIONS=10
STREAMING_ENABLED=true
TOOLS_ENABLED=true
RATE_LIMIT_PER_MINUTE=30
