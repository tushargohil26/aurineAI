# AuraCode v2.0 - Configuration
# AuraCode works out of the box with free cloud AI (no setup needed!)
# Use /connect in AuraCode to set up your preferred provider

# AI Provider: google, groq, openai, anthropic, deepseek, openrouter, ollama
AI_PROVIDER=google

# Cloud API Keys (at least one recommended for reliability)
# Free: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Free: https://console.groq.com/keys
GROQ_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
# https://build.nvidia.com/
NVIDIA_API_KEY=

# Local Ollama (optional - auto-detected, not required)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Database
VECTOR_DB=./vector_store.sqlite3
DATA_DIR=./data
