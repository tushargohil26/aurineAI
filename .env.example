# Aurine AI Assistant - Configuration
# Aurine works out of the box with local AI (no API keys needed!)
# Just install Ollama: https://ollama.com

# AI Provider: aurine (local), ollama, google, groq, openai, anthropic, deepseek, openrouter
AI_PROVIDER=aurine

# --- LOCAL AI (Recommended - No API Key) ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
AURINE_NATIVE_MODEL=aurine-coder
AURINE_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- CLOUD PROVIDERS (Optional - Use if you want cloud AI) ---
# At least one key needed if AI_PROVIDER is not aurine/ollama

# Free: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Free: https://console.groq.com/keys
GROQ_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# https://cloud.sambanova.ai/
SAMBANOVA_API_KEY=
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=
# https://build.nvidia.com/
NVIDIA_API_KEY=

# Cloud Models
GOOGLE_CHAT_MODEL=gemini-2.0-flash
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# Database
VECTOR_DB=./vector_store.sqlite3
DATA_DIR=./data
