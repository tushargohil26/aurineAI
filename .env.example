# AuraCode AI Provider - works with or without Ollama
# If Ollama is not running, auto-falls back to first available cloud key below
AI_PROVIDER=aurine

# Cloud API Keys (at least one recommended for reliability)
# Free: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
# Free: https://console.groq.com/keys
GROQ_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
# https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Local Ollama (optional - auto-detected)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5-coder:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Database
VECTOR_DB=./vector_store.sqlite3
DATA_DIR=./data

# Google OAuth (for web login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
